{
  "name": "ccna-study-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "compile:ccna": "node scripts/compileCcnaPackages.mjs",
    "import:source-bank": "node scripts/importSourceBank.mjs",
    "build:clean-bank": "node scripts/buildCleanBank.mjs all",
    "build:clean-bank:domain": "node scripts/buildCleanBank.mjs",
    "validate:clean-bank": "node scripts/validateCleanBank.mjs",
    "validate:compiled": "node scripts/validateCompiledModules.mjs",
    "validate:pipeline": "npm run validate:clean-bank && npm run validate:answer-reviews && npm run validate:compiled && npm run validate:single-source && npm run validate:voice && npm run validate:answer-voice",
    "build:kb": "node scripts/buildKnowledgeBase.mjs",
    "compile:clean-questions": "node scripts/compileCleanQuestionsModule.mjs",
    "compile:shelved-questions": "node scripts/compileShelvedQuestionsModule.mjs",
    "promote:shelved": "node scripts/promoteShelved.mjs",
    "compile:kb-module": "node scripts/compileKnowledgeBaseModule.mjs",
    "migrate:legacy-clean-bank": "node scripts/migrateLegacyCleanBank.mjs",
    "build:domain1-clean-bank": "node scripts/buildDomain1CleanBank.mjs",
    "kb:full": "npm run onenote:pipeline && npm run import:source-bank && npm run build:clean-bank && npm run build:domain1-clean-bank && npm run validate:clean-bank && npm run build:kb && npm run compile:kb-module && npm run compile:clean-questions && npm run compile:shelved-questions && npm run compile:ccna",
    "kb:domain4": "node scripts/buildCleanBank.mjs 4 && npm run validate:clean-bank && npm run compile:clean-questions",
    "refresh:answer-reviews": "node scripts/compileCkuTrapIndex.mjs && node scripts/refreshAnswerReviews.mjs",
    "compile:cku-traps": "node scripts/compileCkuTrapIndex.mjs",
    "validate:answer-reviews": "node scripts/validateAnswerReviews.mjs",
    "validate:reading-explanation": "node scripts/validateReadingExplanation.mjs",
    "onenote:sync": "node scripts/syncOneNoteRaw.mjs",
    "onenote:import": "node scripts/importOneNote.mjs",
    "kb:merge-onenote": "node scripts/mergeOneNoteToKb.mjs",
    "kb:compile-curated": "node scripts/compileKbToCurated.mjs",
    "validate:topic-map": "node scripts/validateTopicMap.mjs",
    "validate:onenote-import": "node scripts/validateOneNoteImport.mjs",
    "validate:single-source": "node scripts/validateSingleSource.mjs",
    "validate:content-depth": "node scripts/validateContentDepth.mjs",
    "validate:answer-voice": "node scripts/validateAnswerVoice.mjs",
    "validate:voice": "node scripts/validateVoice.mjs",
    "sanitize:kb-prose": "node scripts/sanitizeKbProse.mjs",
    "regenerate:answer-voice": "node scripts/regenerateAnswerVoice.mjs",
    "voice:pipeline": "npm run onenote:pipeline && npm run validate:voice && npm run validate:reading-explanation && npm run regenerate:answer-voice && npm run validate:answer-voice",
    "onenote:pipeline": "npm run onenote:sync && npm run validate:topic-map && npm run onenote:import && npm run sanitize:kb-prose && npm run kb:merge-onenote && npm run kb:compile-curated && npm run validate:onenote-import && npm run validate:single-source && npm run validate:content-depth",
    "test": "vitest run",
    "audit:coverage": "node scripts/auditContentCoverage.mjs",
    "generate:improvement-logs": "node scripts/generateImprovementLogs.mjs",
    "lint": "eslint src"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "vite": "^5.2.0",
    "vitest": "^4.1.8"
  }
}
